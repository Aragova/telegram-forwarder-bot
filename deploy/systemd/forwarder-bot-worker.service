[Unit]
Description=Telegram Forwarder Bot Worker Role
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=forwarder
Group=forwarder
WorkingDirectory=/opt/telegram-forwarder-bot
EnvironmentFile=/etc/forwarder-bot/forwarder.env
ExecStart=/usr/bin/python3 /opt/telegram-forwarder-bot/bot.py --role worker
Restart=always
RestartSec=5
TimeoutStopSec=30
KillSignal=SIGINT

[Install]
WantedBy=multi-user.target
