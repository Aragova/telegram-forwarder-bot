[Unit]
Description=Telegram Forwarder Bot Runtime Role: UI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=forwarder
Group=forwarder
WorkingDirectory=/opt/telegram-forwarder-bot
EnvironmentFile=/etc/forwarder-bot/forwarder.env
ExecStart=/usr/bin/python3 /opt/telegram-forwarder-bot/bot.py --role bot
Restart=on-failure
RestartSec=5
TimeoutStopSec=45
KillSignal=SIGINT

[Install]
WantedBy=multi-user.target
